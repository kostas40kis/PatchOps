{
  "manifest_version": "1",
  "patch_name": "example_generic_python_patch_bundle",
  "active_profile": "generic_python",
  "target_project_root": "C:/dev/patchops",
  "backup_files": [
    "docs/example_patch_note.md",
    "tests/test_example_patch_note_current.py"
  ],
  "files_to_write": [
    {
      "path": "docs/example_patch_note.md",
      "content": null,
      "content_path": "content/docs/example_patch_note.md",
      "encoding": "utf-8"
    },
    {
      "path": "tests/test_example_patch_note_current.py",
      "content": null,
      "content_path": "content/tests/test_example_patch_note_current.py",
      "encoding": "utf-8"
    }
  ],
  "validation_commands": [
    {
      "name": "example_patch_note_contract",
      "program": "py",
      "args": [
        "-m",
        "pytest",
        "-q",
        "tests/test_example_patch_note_current.py"
      ],
      "working_directory": ".",
      "use_profile_runtime": false,
      "allowed_exit_codes": [
        0
      ]
    }
  ],
  "smoke_commands": [],
  "audit_commands": [],
  "cleanup_commands": [],
  "archive_commands": [],
  "failure_policy": {},
  "report_preferences": {
    "report_dir": null,
    "report_name_prefix": "example_generic_python_patch_bundle",
    "write_to_desktop": true
  },
  "tags": [
    "example",
    "bundle",
    "manual_unzip",
    "single_launcher",
    "flat_archive"
  ],
  "notes": "Maintained example bundle for the zip-first manual-unzip stage."
}

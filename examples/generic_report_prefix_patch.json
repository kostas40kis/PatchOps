{
  "manifest_version": "1",
  "patch_name": "generic_report_prefix_example",
  "active_profile": "generic_python",
  "target_project_root": "C:/dev/some_other_project",
  "backup_files": [],
  "files_to_write": [
    {
      "path": "REPORT_PREFIX_EXAMPLE.txt",
      "content": "PatchOps report prefix example.\n",
      "content_path": null,
      "encoding": "utf-8"
    }
  ],
  "validation_commands": [
    {
      "name": "python_version",
      "program": "python",
      "args": [
        "--version"
      ],
      "working_directory": ".",
      "use_profile_runtime": false,
      "allowed_exit_codes": [
        0
      ]
    }
  ],
  "smoke_commands": [],
  "audit_commands": [],
  "cleanup_commands": [],
  "archive_commands": [],
  "failure_policy": {},
  "report_preferences": {
    "report_dir": null,
    "report_name_prefix": "generic_prefix_demo",
    "write_to_desktop": true
  },
  "tags": [
    "example",
    "generic_python",
    "report_preferences"
  ],
  "notes": "Demonstrates deterministic report filename prefixes while keeping Desktop evidence enabled."
}

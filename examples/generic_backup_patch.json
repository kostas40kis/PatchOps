{
  "manifest_version": "1",
  "patch_name": "generic_stage1_example_backup",
  "active_profile": "generic_python",
  "target_project_root": "C:/dev/some_other_project",
  "backup_files": [
    "README_generated_by_patchops.txt"
  ],
  "files_to_write": [
    {
      "path": "README_generated_by_patchops.txt",
      "content": "Generic Python backup-proof example patch manifest.\n",
      "encoding": "utf-8"
    }
  ],
  "validation_commands": [
    {
      "name": "python_version",
      "program": "python",
      "args": [
        "--version"
      ],
      "working_directory": ".",
      "use_profile_runtime": false,
      "allowed_exit_codes": [
        0
      ]
    }
  ],
  "smoke_commands": [],
  "audit_commands": [],
  "cleanup_commands": [],
  "archive_commands": [],
  "failure_policy": {},
  "report_preferences": {
    "report_dir": null,
    "report_name_prefix": null,
    "write_to_desktop": true
  },
  "tags": [
    "example",
    "generic_python",
    "backup_proof"
  ],
  "notes": "Apply this after generic_python_patch.json to prove backup behavior before using trader-profile manifests."
}
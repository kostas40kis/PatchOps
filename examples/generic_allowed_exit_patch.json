{
  "manifest_version": "1",
  "patch_name": "generic_allowed_exit_example",
  "active_profile": "generic_python",
  "target_project_root": "C:/dev/some_other_project",
  "backup_files": [],
  "files_to_write": [
    {
      "path": "ALLOWED_EXIT_EXAMPLE.txt",
      "content": "PatchOps allowed-exit-code example.\n",
      "content_path": null,
      "encoding": "utf-8"
    }
  ],
  "validation_commands": [
    {
      "name": "intentional_non_zero_ok",
      "program": "python",
      "args": [
        "-c",
        "import sys; print('allowed exit example'); raise SystemExit(3)"
      ],
      "working_directory": ".",
      "use_profile_runtime": false,
      "allowed_exit_codes": [
        0,
        3
      ]
    }
  ],
  "smoke_commands": [],
  "audit_commands": [],
  "cleanup_commands": [],
  "archive_commands": [],
  "failure_policy": {},
  "report_preferences": {
    "report_dir": null,
    "report_name_prefix": "generic_allowed_exit_demo",
    "write_to_desktop": true
  },
  "tags": [
    "example",
    "generic_python",
    "allowed_exit_codes"
  ],
  "notes": "Demonstrates how allowed_exit_codes can authorize a non-zero command result when that behavior is expected."
}

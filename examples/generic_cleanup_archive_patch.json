{
  "manifest_version": "1",
  "patch_name": "generic_cleanup_archive_example",
  "active_profile": "generic_python",
  "target_project_root": "C:/dev/some_other_project",
  "backup_files": [],
  "files_to_write": [
    {
      "path": "CLEANUP_ARCHIVE_EXAMPLE.txt",
      "content": "PatchOps cleanup/archive example.\n",
      "content_path": null,
      "encoding": "utf-8"
    }
  ],
  "validation_commands": [
    {
      "name": "python_version",
      "program": "python",
      "args": [
        "--version"
      ],
      "working_directory": ".",
      "use_profile_runtime": false,
      "allowed_exit_codes": [
        0
      ]
    }
  ],
  "smoke_commands": [],
  "audit_commands": [],
  "cleanup_commands": [
    {
      "name": "cleanup_marker",
      "program": "python",
      "args": [
        "-c",
        "print('cleanup ok')"
      ],
      "working_directory": ".",
      "use_profile_runtime": false,
      "allowed_exit_codes": [
        0
      ]
    }
  ],
  "archive_commands": [
    {
      "name": "archive_marker",
      "program": "python",
      "args": [
        "-c",
        "print('archive ok')"
      ],
      "working_directory": ".",
      "use_profile_runtime": false,
      "allowed_exit_codes": [
        0
      ]
    }
  ],
  "failure_policy": {},
  "report_preferences": {
    "report_dir": ".\\data\\runtime\\reports",
    "report_name_prefix": "generic_cleanup_archive_demo",
    "write_to_desktop": false
  },
  "tags": [
    "example",
    "generic_python",
    "command_groups"
  ],
  "notes": "Demonstrates how cleanup and archive commands should be authored when a patch needs explicit reported follow-up steps."
}
